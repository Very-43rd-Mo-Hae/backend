APP_PORT=8080

DB_SCHEMA=mohae
BATCH_SCHEMA=mohae_batch
DB_USER_NAME=relink
DB_PASSWORD=change-me
BATCH_DB_USER_NAME=relink
BATCH_DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

REDIS_HOST=redis
REDIS_PORT=6379

SPRING_SQL_INIT_MODE=always
SPRING_JPA_HIBERNATE_DDL_AUTO=update

JWT_SECRET=change-this-to-a-long-random-production-secret

GOOGLE_CLIENT_ID_WEB=replace-me
GOOGLE_CLIENT_ID_ANDROID=replace-me
GOOGLE_CLIENT_ID_IOS=replace-me

WEB_PUSH_ENABLED=true
WEB_PUSH_SUBJECT=mailto:admin@example.com
WEB_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
WEB_PUSH_PRIVATE_KEY=replace-with-vapid-private-key

NOTIFICATION_DEDUP_PREFIX=notification:dedup
NOTIFICATION_DEDUP_TTL_SECONDS=300
NOTIFICATION_OUTBOX_ENABLED=true
NOTIFICATION_OUTBOX_BATCH_SIZE=50
NOTIFICATION_OUTBOX_FIXED_DELAY_MILLIS=5000

CHAT_STORAGE_TYPE=local
CHAT_LOCAL_PUBLIC_BASE_URL=http://localhost:8080/uploads
